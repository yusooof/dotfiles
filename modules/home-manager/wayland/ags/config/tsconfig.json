{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "paths": {
      "gi://*": ["./@girs/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "@girs/*.d.ts",
    "env.d.ts"
  ]
}
